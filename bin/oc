#!/bin/bash
# OpenCode Docker Runner
# Usage: oc [-p <PROFILE>] [-v <host>:<container>] ... <workspace-path> [docker-args...]"

set -e

PROFILE="default"
WORKSPACE_PATH="."
ADDITIONAL_VOLUMES=()
DOCKER_ARGS=()

# Parse flags with getopts
while getopts "e:p:v:" opt; do
  case $opt in
    e) ENV_FILE="$OPTARG" ;;
    p) PROFILE="$OPTARG" ;;
    v) ADDITIONAL_VOLUMES+=("-v" "$OPTARG") ;;
    \?) echo "Invalid option: -$OPTARG" >&2; exit 1 ;;
    :) echo "Option -$OPTARG requires an argument" >&2; exit 1 ;;
  esac
done

# Shift past the processed flags
shift $((OPTIND - 1))

# Remaining arguments: workspace path and docker args
if [[ $# -gt 0 ]]; then
  WORKSPACE_PATH="$1"
  shift
  DOCKER_ARGS=("$@")
fi

# Build docker run command
# Extract volumes from docker-compose.yml and convert them to docker run flags
EXTRA_FLAGS=()

# Shared volumes
EXTRA_FLAGS+=("-v" "opencode-npm:/home/node/.npm-global")
EXTRA_FLAGS+=("-v" "opencode-pip:/usr/local/lib/python3/dist-packages")

# Data volumes with PROFILE
EXTRA_FLAGS+=("-v" "opencode-data-$PROFILE:/home/node/.local")

# Workspace override
EXTRA_FLAGS+=("-v" "$WORKSPACE_PATH:/workspace")

# Additional volumes from CLI
EXTRA_FLAGS+=("${ADDITIONAL_VOLUMES[@]}")

if [[ -n "$ENV_FILE" ]]; then
  if [[ ! -f "$ENV_FILE" ]]; then
    echo "Error: Environment file '$ENV_FILE' not found." >&2
    exit 1
  fi
  EXTRA_FLAGS+=("--env-file" "$ENV_FILE")
fi

# Run docker with cleanup on exit
docker run --rm -it \
  "${EXTRA_FLAGS[@]}" \
  opencode:latest \
  "${DOCKER_ARGS[@]}"

EXIT_CODE=$?
exit $EXIT_CODE
